# Ollama — local LLM server
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ChromaDB — vector database
CHROMA_HOST=localhost
CHROMA_PORT=8001

# Embedding model (sentence-transformers)
# bge-base: 4x faster than bge-large with nearly identical retrieval quality
# Swap to bge-small for ~12x speed, or bge-large for maximum quality
EMBED_MODEL_NAME=BAAI/bge-base-en-v1.5

# Chunking strategy
# CHUNK_SIZE: target characters per chunk (not tokens)
# CHUNK_OVERLAP: shared characters between adjacent chunks for context continuity
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Retrieval — how many candidates to fetch before reranking
TOP_K_RETRIEVE=20
# Reranking — final number of passages sent to the LLM
TOP_K_RERANK=5

# Persistence — BM25 index is serialized to JSON on disk
BM25_INDEX_PATH=./data/bm25_index.json

# Evaluation quality gates (0.0 – 1.0)
# CI will fail if metrics drop below these thresholds on a PR
EVAL_FAITHFULNESS_THRESHOLD=0.75
EVAL_ANSWER_RELEVANCY_THRESHOLD=0.70
